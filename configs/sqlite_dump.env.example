# sqlite_dump.sh overrides — copy to /opt/monitor/backups/.env on the host and edit.
# sqlite_dump.sh sources this file (if present, next to the script) before its own
# defaults, so anything set here wins.

# Google Drive destination (rclone remote name + path). Default shown.
#GDRIVE_REMOTE=gdrive:backups/kz_behappy/monitor

# Retention windows in days. Local host is short (scarce disk); Drive is the archive.
#LOCAL_RETENTION_DAYS=7
#REMOTE_RETENTION_DAYS=14
