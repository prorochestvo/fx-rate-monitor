# SQLite database file path
SQLITEDB_DSN=sqlite://_:_@_:_/monitor.db

# Telegram Bot DSN: token@admin_chat_id
# Example: 123456789:AABBccDDeeFF-xxxxxxxx@-1001234567890
TELEGRAMBOT_DSN=tbot://YOUR_ADMIN_CHAT_ID:@YOUR_BOT_TOKEN/

# Optional HTTP/SOCKS5 proxy URL (leave empty to disable)
# PROXY_URL=socks5://user:pass@host:port
PROXY_URL=