# SQLite database file path
SQLITEDB_DSN=sqlite://_:_@_:_/monitor.db

# Telegram Bot DSN: token@admin_chat_id
# Example: 123456789:AABBccDDeeFF-xxxxxxxx@-1001234567890
TELEGRAMBOT_DSN=tbot://YOUR_ADMIN_CHAT_ID:@YOUR_BOT_TOKEN/

# Used by cmd/rulegen only — cmd/web does NOT read AI_*_DSN.
# AI Primary DSN (mandatory): Groq is the recommended default.
# Encode your API key as URL-safe base64: echo -n "gsk_..." | base64 | tr '+/' '-_'
# Model must support response_format json_schema strict mode (see groq.go comment).
AI_PRIMARY_DSN=groq://_:<base64url(GROQ_KEY)>@api.groq.com/openai/v1?model=openai/gpt-oss-20b&timeout=30s

# AI Fallback DSN (optional): absent = silent stub; malformed = fatal error.
# Intended for OpenAI or a high-quality OpenRouter model as escalation path.
# AI_FALLBACK_DSN=openrouterai://_:<base64url(OPENROUTER_KEY)>@openrouter.ai/api/v1?model=anthropic/claude-3.5-sonnet&timeout=60s
# AI_FALLBACK_DSN=openai://_:<base64url(OPENAI_KEY)>@api.openai.com/v1?model=gpt-4o&timeout=60s

# Optional HTTP/SOCKS5 proxy URL (leave empty to disable)
# PROXY_URL=socks5://user:pass@host:port
PROXY_URL=